---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout90s.astro";
const allPosts = await getCollection('blog-90s', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const categories = [...new Set(allPosts.map((post) => post.data.category).flat())];
const pageTitle = "Categories";
---
<BaseLayout pageTitle={pageTitle}>
  <ul>
    {
      categories.map((category) => (
        <li>
          <a href={`/jgoodman-website/90s/category/${category}`}>{category}</a>
        </li>
      ))
    }
  </ul>
</BaseLayout>