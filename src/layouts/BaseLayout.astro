---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import '../styles/more-modern-reset.css';

const { pageTitle } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/jgoodman-website/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>J. Goodman | {pageTitle}</title>
	</head>

	<body>
    <Header></Header>
    <main>
      <h1>{pageTitle}</h1>
      <slot />
    </main>
		<Footer></Footer>
	</body>

</html>